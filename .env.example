# Copia este archivo como .env y completa con tus credenciales reales.

# --- Pinecone ---
PINECONE_API_KEY=tu_pinecone_api_key
PINECONE_HOST=tu_pinecone_host
PINECONE_INDEX=unab-rag-agent

# --- Gemini (multiquery + respuesta final) ---
GEMINI_API_KEY=tu_gemini_api_key
GEMINI_MODEL=tu_gemini_model

# --- Cohere (clasificación) ---
COHERE_API_KEY=tu_cohere_api_key
COHERE_MODEL=tu_cohere_model

# --- Embeddings ---
EMBEDDING_MODEL=tu_embedding_model

# --- Retrieval ---
RETRIEVER_K=4

# --- App ---
APP_HOST=0.0.0.0
APP_PORT=8000
CORS_ORIGINS=*

